{
  "name": "@agentmonitors/website",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "test": "vitest run",
    "check": "tsc --noEmit",
    "check:links": "start-server-and-test start http://localhost:3000 link-check",
