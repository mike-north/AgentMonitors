{
  "name": "@agentmonitors/source-api-poll",
  "description": "HTTP endpoint polling and change detection for Agent Monitors",
  "version": "0.3.0",
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/public.d.ts",
  "exports": {
    ".": {
      "types": "./dist/public.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "agentmonitor:observation-source"
  ],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json && api-extractor run --local --verbose",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "check:api-report": "api-extractor run --local --verbose",
    "ci:api-report": "api-extractor run --verbose"
  },
  "dependencies": {
    "@agentmonitors/core": "workspace:*"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.15.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mike-north/AgentMonitors.git",
    "directory": "plugins/source-api-poll"
  },
  "bugs": {
    "url": "https://github.com/mike-north/AgentMonitors/issues"
  },
  "homepage": "https://github.com/mike-north/AgentMonitors/tree/main/plugins/source-api-poll#readme"
}
