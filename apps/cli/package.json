{
  "name": "@agentmonitors/cli",
  "description": "CLI for Agent Monitors — validate, scan, query, and manage observation inboxes",
  "version": "0.3.0",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "bin": {
    "agentmonitors": "./dist/index.cjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "check": "tsc --noEmit",
