{
  "name": "@agentmonitors/core",
  "description": "Core library for Agent Monitors — schema, parser, inbox, plugin interface, and notification engine",
  "version": "0.10.0",
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/public.d.ts",
  "exports": {
    ".": {
      "types": "./dist/public.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json && api-extractor run --local --verbose",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "check:api-report": "api-extractor run --local --verbose",
    "ci:api-report": "api-extractor run --verbose"
  },
  "license": "MIT",
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "better-sqlite3": "^11.9.1",
    "cel-js": "0.8.2",
    "drizzle-orm": "^0.45.2",
    "glob": "^11.0.1",
    "gray-matter": "^4.0.3",
    "jq-in-the-browser": "0.7.2",
    "ulid": "^2.3.0",
    "zod": "^3.25.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.0",
    "drizzle-kit": "^0.31.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mike-north/AgentMonitors.git",
    "directory": "libs/core"
  },
  "bugs": {
    "url": "https://github.com/mike-north/AgentMonitors/issues"
  },
  "homepage": "https://github.com/mike-north/AgentMonitors/tree/main/libs/core#readme"
}
