{
  "name": "agentmonitors-workspace",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "NX_TUI=false nx run-many --target=build --exclude=agentmonitors-workspace,@agentmonitors/website",
    "check": "pnpm check:packages && pnpm check:workspace && pnpm check:aipm",
    "check:aipm": "aipm validate",
    "check:changesets:no-major": "node scripts/check-no-major-changesets.mjs",
    "audit:prod": "pnpm audit --prod --audit-level high",
    "check:dependency-audit": "node scripts/check-dependency-audit.mjs",
    "check:packages": "NX_TUI=false nx run-many --target=check --exclude=agentmonitors-workspace,@agentmonitors/website",
    "check:lint-ts": "eslint .",
    "check:format": "prettier --check .",
    "check:test-ext": "node scripts/check-test-file-extensions.mjs",
    "check:workspace": "pnpm check:lint-ts && pnpm check:format && pnpm check:test-ext",
    "changeset": "changeset",
    "fix:lint-ts": "eslint . --fix",
    "fix:format": "prettier --write .",
    "prepare": "husky",
    "publish:packages": "node scripts/publish-release-packages.mjs",
    "publish:packages:dry-run": "node scripts/publish-release-packages.mjs --dry-run",
    "release": "pnpm build && pnpm publish:packages",
    "test": "NX_TUI=false nx run-many --target=test --exclude=agentmonitors-workspace",
    "test:scripts": "vitest run --config scripts/vitest.config.ts",
    "test:serial": "NX_TUI=false nx run @agentmonitors/cli:test:serial",
    "test:standalone-consumer": "node scripts/test-standalone-consumer.mjs",
    "test:e2e-fresh-install-hooks": "node scripts/test-e2e-fresh-install-hooks.mjs",
    "clean": "NX_TUI=false nx run-many --target=clean --exclude=agentmonitors-workspace && nx reset",
    "check:api-report": "NX_TUI=false nx run-many --target=check:api-report --exclude=agentmonitors-workspace --parallel=1",
    "fix:api-report": "NX_TUI=false nx run-many --target=fix:api-report --exclude=agentmonitors-workspace --parallel=1",
    "version:packages": "changeset version"
  },
  "lint-staged": {
    "*": "prettier --ignore-unknown --write"
  },
  "author": "Mike North <michael.l.north@gmail.com>",
  "license": "MIT",
  "packageManager": "pnpm@11.12.0+sha512.820a6fbd0d9f04c226638002aead1e45340a9139dd5dc077c1d83ef44aa2481c8eb6637b4c9aa696a3c7e35ba818e49cf27213e5f2b91138d09b7a3e26e898ba",
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@ai-plugin-marketplace/cli": "^0.2.0",
    "@ai-plugin-marketplace/core": "^0.3.0",
    "@api-extractor-tools/eslint-plugin": "^0.1.0",
    "@changesets/cli": "^2.29.7",
    "@eslint/js": "^10.0.1",
    "@microsoft/api-extractor": "^7.57.6",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "fixturify-project": "^7.1.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "nx": "^22.5.4",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18",
    "yaml": "^2.9.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mike-north/AgentMonitors.git"
  },
  "bugs": {
    "url": "https://github.com/mike-north/AgentMonitors/issues"
  },
  "homepage": "https://github.com/mike-north/AgentMonitors#readme"
}
