{
  "name": "agentmonitors-workspace",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "NX_TUI=false nx run-many --target=build --exclude=agentmonitors-workspace,@agentmonitors/website",
    "check": "pnpm check:packages && pnpm check:workspace",
    "check:packages": "NX_TUI=false nx run-many --target=check --exclude=agentmonitors-workspace,@agentmonitors/website",
    "check:lint-ts": "eslint .",
    "check:format": "prettier --check .",
    "check:workspace": "pnpm check:lint-ts && pnpm check:format",
    "fix:lint-ts": "eslint . --fix",
    "fix:format": "prettier --write .",
    "test": "NX_TUI=false nx run-many --target=test --exclude=agentmonitors-workspace",
    "clean": "NX_TUI=false nx run-many --target=clean --exclude=agentmonitors-workspace",
    "check:api-report": "NX_TUI=false nx run-many --target=check:api-report --exclude=agentmonitors-workspace"
  },
  "author": "Mike North <michael.l.north@gmail.com>",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.30.3",
  "devDependencies": {
    "@api-extractor-tools/eslint-plugin": "^0.1.0",
    "@eslint/js": "^10.0.1",
    "@microsoft/api-extractor": "^7.57.6",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "nx": "^22.5.4",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "nx"
    ]
  }
}
