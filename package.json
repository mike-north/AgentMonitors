{
  "name": "agentmonitors-workspace",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "NX_TUI=false nx run-many --target=build --exclude=agentmonitors-workspace,@mike-north/website",
    "check": "pnpm check:packages && pnpm check:workspace",
    "check:changesets:no-major": "node scripts/check-no-major-changesets.mjs",
    "check:packages": "NX_TUI=false nx run-many --target=check --exclude=agentmonitors-workspace,@mike-north/website",
    "check:lint-ts": "eslint .",
    "check:format": "prettier --check .",
    "check:workspace": "pnpm check:lint-ts && pnpm check:format",
    "changeset": "changeset",
    "fix:lint-ts": "eslint . --fix",
    "fix:format": "prettier --write .",
    "prepare": "husky",
    "publish:packages": "node scripts/publish-release-packages.mjs",
    "release": "pnpm build && pnpm publish:packages",
    "test": "NX_TUI=false nx run-many --target=test --exclude=agentmonitors-workspace",
    "test:standalone-consumer": "node scripts/test-standalone-consumer.mjs",
    "clean": "NX_TUI=false nx run-many --target=clean --exclude=agentmonitors-workspace",
    "check:api-report": "NX_TUI=false nx run-many --target=check:api-report --exclude=agentmonitors-workspace",
    "version:packages": "changeset version"
  },
  "author": "Mike North <michael.l.north@gmail.com>",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.30.3",
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@api-extractor-tools/eslint-plugin": "^0.1.0",
    "@eslint/js": "^10.0.1",
    "@microsoft/api-extractor": "^7.57.6",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "fixturify-project": "^7.1.3",
    "husky": "^9.1.7",
    "nx": "^22.5.4",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "nx"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mike-north/AgentMonitors.git"
  },
  "bugs": {
    "url": "https://github.com/mike-north/AgentMonitors/issues"
  },
  "homepage": "https://github.com/mike-north/AgentMonitors#readme"
}
