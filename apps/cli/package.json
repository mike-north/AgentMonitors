{
  "name": "@agentmonitors/cli",
  "description": "CLI for Agent Monitors — validate, scan, query, and manage observation inboxes",
  "version": "0.9.0",
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "bin": {
    "agentmonitors": "./dist/index.cjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:serial": "vitest run --config vitest.serial.config.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@agentmonitors/core": "workspace:*",
    "@agentmonitors/source-api-poll": "workspace:*",
    "@agentmonitors/source-command-poll": "workspace:*",
    "@agentmonitors/source-file-fingerprint": "workspace:*",
    "@agentmonitors/source-incoming-changes": "workspace:*",
    "@agentmonitors/source-schedule": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@toon-format/toon": "^2.3.0",
    "better-sqlite3": "^11.9.1",
    "commander": "^14.0.3",
    "glob": "^11.0.1",
    "is-agentic-tui": "^0.2.0",
    "zod": "^3.25.76"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.15.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mike-north/AgentMonitors.git",
    "directory": "apps/cli"
  },
  "bugs": {
    "url": "https://github.com/mike-north/AgentMonitors/issues"
  },
  "homepage": "https://github.com/mike-north/AgentMonitors/tree/main/apps/cli#readme"
}
