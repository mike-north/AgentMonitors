{
  "name": "@agentmonitors/source-file-fingerprint",
  "description": "File change detection via SHA-256 fingerprinting for Agent Monitors",
  "version": "0.0.2",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/public.d.ts",
  "exports": {
    ".": {
      "types": "./dist/public.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "agentmonitor:observation-source"
  ],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json && api-extractor run --local --verbose",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "check:api-report": "api-extractor run --local --verbose",
    "ci:api-report": "api-extractor run --verbose"
  },
  "dependencies": {
    "@agentmonitors/core": "workspace:*",
    "glob": "^11.0.1"
  },
  "license": "UNLICENSED",
  "devDependencies": {
    "@types/node": "^22.15.0"
  }
}
