{
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noPropertyAccessFromIndexSignature": true,
    "exactOptionalPropertyTypes": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "paths": {
      "@mike-north/core": ["libs/core/dist/rollup.d.ts"],
      "@mike-north/source-file-fingerprint": [
        "plugins/source-file-fingerprint/dist/rollup.d.ts"
      ],
      "@mike-north/source-api-poll": [
        "plugins/source-api-poll/dist/rollup.d.ts"
      ],
      "@mike-north/source-schedule": [
        "plugins/source-schedule/dist/rollup.d.ts"
      ]
    },
    "target": "ES2022",
    "lib": ["ES2022"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmitOnError": true,
    "isolatedModules": true,
    "skipLibCheck": true
  }
}
